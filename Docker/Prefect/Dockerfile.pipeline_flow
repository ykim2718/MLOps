# Dockerfile.pipeline_flow — shared team Pipeline Flow image (libraries + orchestrator)
FROM python:3.11.15
RUN apt-get update && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work
COPY requirements.txt .               # required: prefect, boto3
RUN pip install --no-cache-dir -r requirements.txt

COPY pipeline.py .                    # orchestrator (deployment entrypoint); team repo is fetched at runtime into a per-run worktree
